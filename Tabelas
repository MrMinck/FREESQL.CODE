CREATE TABLE ALUNOS 
(
NOME VARCHAR2(30) NOT NULL, 
IDADE NUMBER NOT NULL, 
EMAIL VARCHAR2(100)
);


CREATE TABLE DISCIPLINAS 
(
CODIGO VARCHAR2(3) NOT NULL PRIMARY KEY, 
DISCIPLINAS VARCHAR2(60) NOT NULL, 
STATUS BOOLEAN NOT NULL
);


CREATE TABLE PROFESSORES 
(
CODIGO INT NOT NULL PRIMARY KEY,
NOME VARCHAR2(30) NOT NULL, 
ESCOLA VARCHAR2(60) NOT NULL, 
NUMERO NUMBER, 
DISCIPLINA VARCHAR2(3) NOT NULL REFERENCES DISCIPLINAS (CODIGO)
);


